{
  "manifest_version": 3,
  "name": "Password Generator",
  "version": "1.0.0",
  "description": "Generatore di password sicure, locale e stand-alone. Nessun dato salvato, nessuna password tracciata.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["clipboardWrite"]
}
